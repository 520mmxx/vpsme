# ============================================================
# 环境配置（含敏感信息）
# ============================================================
.env
.env.*
!.env.example
!.env.example.cn

# ============================================================
# 子项目 .env（含真实 Cookie / Token）
# ============================================================
bigbat/.env
bigbat/data/
kiro-gateway/.env
proxy/.env

# ============================================================
# Genspark Cookie 池文件
# ============================================================
proxy-pool/cookies/
proxy-pool/cookies.json

# ============================================================
# Hermes Agent 配置（可能含 api_key）
# ============================================================
hermes/config.yaml
hermes/*.log
hermes/*.db

# ============================================================
# SearXNG 配置文件（含 secret_key）
# ============================================================
searxng/settings.yml
searxng/uwsgi.ini
searxng/*.bak

# ============================================================
# Docker 数据 / 自动生成
# ============================================================
docker-data/
agent-files/*
!agent-files/.gitkeep
bigbat/data/

# ============================================================
# 系统级配置（各 VPS 不同，由 install.sh 生成）
# ============================================================
nginx/
systemd/
tunnel/

# ============================================================
# IDE / 编辑器
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*.swn
.project
.classpath
*.sublime-workspace
*.sublime-project

# ============================================================
# 操作系统
# ============================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ============================================================
# 日志 / 临时 / 构建产物
# ============================================================
*.log
logs/
tmp/
temp/
*.tmp
*.bak
*.backup
*~
dist/
build/
out/
*.tar.gz
*.zip

# ============================================================
# 用户自定义内容
# ============================================================
skills/custom/
skills/private/
my-tools/
benchmark-results/
browser-e2e-results.json
browser-e2e-transcript.md
.claude/
.planning/
debug-log.md
debug-summary.md

# ============================================================
# Node / Python
# ============================================================
node_modules/
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Generated outputs
OpenDeepSeek-Outputs/
