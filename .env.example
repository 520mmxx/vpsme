# ==================== OpenDeepSeek 环境配置模板 ====================
# 用法：cp .env.example .env，然后编辑 .env 填入你的真实配置
# 注意：不要把 .env 提交到 Git！本文件所有值均为占位符。
# 生成时间：2026-06-29
#
# 快速开始：
#   1. 至少填写 OPDS_LLM_API_KEY（你的 LLM API 密钥）
#   2. 运行 docker compose up -d
#   3. 访问 http://localhost:3000

# ============================================================
# LLM Provider — 核心配置（OpenAI 兼容接口）
# ============================================================
# Provider 类型：deepseek（默认）、custom（自定义 OpenAI 兼容接口）
# OPDS_LLM_PROVIDER=custom

# LLM API 请求地址（OpenAI 兼容接口）
# OPDS_LLM_BASE_URL=http://127.0.0.1:8000/v1

# LLM API 密钥（必填！）
# OPDS_LLM_API_KEY=your-api-key-here

# 默认对话模型名
# OPDS_LLM_MODEL=GPT-5.4

# 高级/Pro 模型名（用于复杂推理任务）
# OPDS_LLM_PRO_MODEL=GPT-5.5 Pro

# Hermes Agent 底层推理 Provider
# HERMES_INFERENCE_PROVIDER=custom

# 前端展示的默认模型 ID
# DEFAULT_MODEL=GPT-5.4

# 自定义模型名称（仅当使用 custom provider 时）
# CUSTOM_MODEL_NAME=GPT-5.4
# CUSTOM_MODEL_BASE_URL=http://127.0.0.1:8000/v1
# CUSTOM_MODEL_API_KEY=your-api-key-here

# DeepSeek 原生 API（备用/直连用）
# DEEPSEEK_API_KEY=your-api-key-here
# DEEPSEEK_API_BASE=https://api.deepseek.com

# ============================================================
# 前端展示 — 默认模型与固定模型列表
# ============================================================
# Open WebUI 下拉列表中显示的默认模型
# DEFAULT_MODELS_FRONTEND=GPT-5.4

# 置顶显示的模型列表（逗号分隔）
# DEFAULT_PINNED_MODELS=GPT-5.5-Pro,GPT-5.4,GPT-5.4-Mini,GPT-5.4-Nano,GPT-5.2-Pro,GPT-5.4-Pro,GPT-5.5,O3-pro,ClaudeSonnet-4.6,Claude-Opus-4.8,Claude-Opus-4.7,Claude-Opus-4.6,Claude-Haiku-4.5,Gemini-3-Flash-Preview,Gemini-3.1-Pro-Preview,Gemini-3.1-Flash-Lite,Gemini-3.5-Flash,DeepSeek-V4-Pro,DeepSeek-V4-Flash,Trinity-Large-Thinking,Minimax-M2.7,Minimax-M3,Kimi-K2.6,Grok-4.20-Reasoning,Grok-4.20

# ============================================================
# Hermes Agent — 内部 API
# ============================================================
# Hermes 内部 API 密钥（建议随机生成：openssl rand -hex 32）
# HERMES_API_KEY=your-api-key-here

# Hermes 最大迭代次数（Agent 单次任务最大工具调用轮数）
# HERMES_MAX_ITERATIONS=48

# Hermes Agent 最大 token 预算
# HERMES_AGENT_MAX_TOKENS=65536

# Hermes API 超时（秒）
# HERMES_API_TIMEOUT=300
# HERMES_API_CALL_STALE_TIMEOUT=120

# Agent 流式输出（false = 关闭流式，改为一次性返回）
# HERMES_AGENT_STREAM=false
# HERMES_PROGRESS_STREAM=true

# 轻量问答走直连，复杂任务走 Hermes Agent
# ENABLE_LIGHTWEIGHT_ROUTING=true

# Agent 轻量问答兜底（Agent 不可用时 fallback 到 lite 模式）
# OPDS_AGENT_FALLBACK_TO_LITE=false

# 图片处理超时（秒）
# IMAGE_BRIDGE_TIMEOUT=600

# Open WebUI 原生工具委派（仍用 OpenWebUI 自带工具循环）
# OPDS_DELEGATE_OPENWEBUI_NATIVE_TOOLS=true

# 共享记忆文件路径（容器内路径）
# OPDS_SHARED_MEMORY_PATH=/host/OpenDeepSeek-Memory/profile.md
# OPDS_MEMORY_SNAPSHOT_MAX_CHARS=4000

# /host 路径显示前缀
# OPDS_HOST_DISPLAY_PREFIX=./agent-files

# 本地产物中心端口
# OPDS_ARTIFACT_PORT=8770
# OPDS_ARTIFACT_ROOT=/host/OpenDeepSeek-Outputs
# OPDS_ARTIFACT_PUBLIC_BASE_URL=http://localhost:8770
# OPDS_ARTIFACT_MAX_FILES=100

# ============================================================
# Open WebUI — 前端配置
# ============================================================
# WebUI 密钥（必填，建议随机生成）
# WEBUI_SECRET_KEY=your-webui-secret-key

# 站点名称
# WEBUI_NAME=OpenDeepSeek

# 界面语言
# DEFAULT_LOCALE=zh-CN

# 认证模式（false = 家庭模式无需登录，true = 团队模式需注册）
# WEBUI_AUTH=false

# 速度优化：关闭不必要的模型调用
# ENABLE_TITLE_GENERATION=false
# ENABLE_TAGS_GENERATION=false
# ENABLE_FOLLOW_UP_GENERATION=false
# ENABLE_CODE_INTERPRETER=false
# ENABLE_RAG_HYBRID_SEARCH=false
# ENABLE_RAG_WEB_SEARCH=false

# 社区分享与更新检查
# ENABLE_COMMUNITY_SHARING=false
# ENABLE_VERSION_UPDATE_CHECK=false
# ENABLE_EASTER_EGGS=false

# ============================================================
# Kiro Gateway — 多模型路由网关
# ============================================================
# Kiro Gateway 内部地址
# KIRO_GATEWAY_URL=http://kiro-gateway:8000

# Kiro Gateway API 密钥
# KIRO_GATEWAY_KEY=your-api-key-here

# Kiro Refresh Token（从 Amazon Q / AWS 获取）
# KIRO_REFRESH_TOKEN=your-kiro-refresh-token

# ============================================================
# GenSpark Proxy — Cookie 与 API 密钥
# ============================================================
# 通用 API 密钥（由 genspark-proxy 和 genspark2api 共享）
# API_SECRET=your-api-key-here

# GenSpark 单 Cookie（简单模式）
# GS_COOKIE=your-genspark-cookie-here

# GenSpark Cookie 池（JSON 格式，多 Cookie 轮询）
# GS_COOKIES_JSON=

# 调试模式
# DEBUG=false

# genspark2api 端口
# GENSPARK2API_PORT=7059

# ============================================================
# Telegram Bot — 聊天机器人
# ============================================================
# Telegram Bot Token（从 @BotFather 获取）
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# 允许使用 Telegram Bot 的用户 ID（逗号分隔，留空=允许所有人）
# TELEGRAM_ALLOWED_USERS=

# 禁用 Telegram fallback IP
# HERMES_TELEGRAM_DISABLE_FALLBACK_IPS=false

# Telegram HTTP 客户端超时设置
# HERMES_TELEGRAM_HTTP_CONNECT_TIMEOUT=30
# HERMES_TELEGRAM_HTTP_READ_TIMEOUT=60
# HERMES_TELEGRAM_HTTP_POOL_TIMEOUT=15

# ============================================================
# QQ Bot — QQ 官方机器人
# ============================================================
# QQ 开放平台 App ID
# QQ_APP_ID=

# QQ 开放平台 Client Secret
# QQ_CLIENT_SECRET=

# 允许所有 QQ 用户访问
# QQ_ALLOW_ALL_USERS=true

# QQ 开放平台 Portal Host
# QQ_PORTAL_HOST=q.qq.com

# 允许所有人访问 Hermes Gateway（QQ/Telegram 等）
# GATEWAY_ALLOW_ALL_USERS=true

# ============================================================
# 网络绑定与文件挂载
# ============================================================
# 服务绑定地址（0.0.0.0 = 所有网卡，127.0.0.1 = 仅本机）
# BIND_HOST=127.0.0.1

# Agent 文件系统宿主机目录（容器内挂载为 /host）
# HERMES_HOST_DIR=./agent-files

# ============================================================
# Docker 资源限制
# ============================================================
# Hermes Agent
# HERMES_CPUS=1.5
# HERMES_MEMORY_LIMIT=1280m

# Open WebUI
# WEBUI_CPUS=1.0
# WEBUI_MEMORY_LIMIT=1024m

# Smart Bridge
# BRIDGE_CPUS=0.5
# BRIDGE_MEMORY_LIMIT=256m

# Ollama（工具调用推理）
# OLLAMA_CPUS=4.0
# OLLAMA_MEMORY_LIMIT=8192m

# SearXNG（联网搜索）
# SEARXNG_CPUS=0.5
# SEARXNG_MEMORY_LIMIT=384m

# ============================================================
# 实时搜索
# ============================================================
# 启用实时搜索
# OPDS_REALTIME_SEARCH_ENABLED=true

# SearXNG 搜索 URL
# OPDS_REALTIME_SEARCH_URL=http://searxng:8080/search?q={query}&format=json

# 搜索超时（秒）
# OPDS_REALTIME_SEARCH_TIMEOUT=4

# 搜索结果最大数量
# OPDS_REALTIME_SEARCH_MAX_RESULTS=6

# Open WebUI RAG 搜索 URL
# SEARXNG_QUERY_URL=http://searxng:8080/search?q=<query>&format=json

# 备用搜索 Provider
# OPDS_SEARCH_PROVIDER=auto

# 国内可选搜索增强 API
# BOCHA_SEARCH_API_KEY=
# JINA_API_KEY=
# BING_SEARCH_V7_SUBSCRIPTION_KEY=

# ============================================================
# RAG / 嵌入模型
# ============================================================
# RAG 嵌入模型
# RAG_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# ============================================================
# 中国网络优化（仅 CN 部署需要）
# ============================================================
# 区域标识
# OPDS_REGION=cn

# 自定义镜像（国内可换成阿里云 ACR / 腾讯云 CCR）
# HERMES_IMAGE=nousresearch/hermes-agent:v2026.6.5
# BRIDGE_IMAGE=opendeepseek-hermes-bridge:cn-local
# OPENWEBUI_IMAGE=openwebui/open-webui:0.9.2
# SEARXNG_IMAGE=searxng/searxng:2026.4.28-ed5955a5c
# OPDS_IMAGE_REGISTRY=registry.cn-hangzhou.aliyuncs.com/opendeepseek
# OPDS_VERSION=0.5.0-cn

# 国内镜像源
# PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
# UV_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
# NPM_CONFIG_REGISTRY=https://registry.npmmirror.com
# PNPM_REGISTRY=https://registry.npmmirror.com

# 离线模式
# OFFLINE_MODE=false
# HF_HUB_OFFLINE=false

# ============================================================
# IM 桥接（可选，按需取消注释并填入凭证）
# ============================================================
# 钉钉机器人
# DINGTALK_CLIENT_ID=
# DINGTALK_CLIENT_SECRET=
# DINGTALK_ALLOWED_USERS=

# 飞书机器人
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_DOMAIN=feishu

# 企业微信机器人
# WECOM_BOT_ID=
# WECOM_SECRET=
# WECOM_ALLOWED_USERS=

# 邮件 IMAP/SMTP
# EMAIL_ADDRESS=
# EMAIL_PASSWORD=
# EMAIL_IMAP_HOST=imap.exmail.qq.com
# EMAIL_SMTP_HOST=smtp.exmail.qq.com

# Matrix 去中心 IM
# MATRIX_HOMESERVER=https://matrix.org
# MATRIX_ACCESS_TOKEN=
# MATRIX_USER_ID=

# Webhook
# WEBHOOK_ENABLED=true
# WEBHOOK_PORT=8644

# ============================================================
# 其他
# ============================================================
# Tailscale 主机名（用于手机/异地远程访问）
# TAILSCALE_HOSTNAME=opendeepseek

# 时区
# TZ=Asia/Shanghai
